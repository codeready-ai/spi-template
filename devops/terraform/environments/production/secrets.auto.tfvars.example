# Copy to `secrets.auto.tfvars` (git-ignored) and fill in real values. Terraform auto-loads any
# *.auto.tfvars file, so no `-var-file` flag is needed.
#
# Variables with sensible defaults (cluster_name, registry, namespace, image_tag, hostname,
# app_url, cluster_issuer, do_spaces_*) are omitted below — override them only if needed.

# DigitalOcean API token — cluster lookup + DOCR image pull.
do_token = "dop_v1_..."

# DigitalOcean Spaces credentials (bucket/region/endpoint default to gym-up-x / nyc3)
do_spaces_key    = "DO00..."
do_spaces_secret = "..."

# Override only if different from the defaults in variables.tf:
# cluster_name   = "elias-interconnect-cluster-001"
# registry       = "registry.digitalocean.com/elias-interconnect-cr1"
# namespace      = "myapp-prod"
# hostname       = "myapp.com"
# cluster_issuer = "letsencrypt-prod"
