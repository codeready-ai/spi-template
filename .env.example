# Copy to `.env` (git-ignored) and fill in real values.

# Public origin used for canonical/OG URLs (build-time). Defaults to https://codeready.ai.
PUBLIC_SITE_URL=https://myapp.codeready.ai

# --- Terraform state backend (DigitalOcean Spaces, S3-compatible) ------------------------------
# `source devops/scripts/load-env.sh` exports these for `terraform init`. The S3 backend reads the
# AWS_* names; the DO_SPACES_* values are mirrored into them if AWS_* are unset.
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=bucket-name-here
DO_SPACES_KEY=
DO_SPACES_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
